            <div class="item"><span class="item-name">Butter Croissant</span><span class="item-desc">Flaky and golden</span></div>
            <div class="item"><span class="item-name">Chocolate Muffin</span><span class="item-desc">Baked fresh every morning</span></div>
            <div class="item"><span class="item-name">Cinnamon Roll</span><span class="item-desc">Warm with cream cheese glaze</span></div>
        </div>

        <!-- Food -->
        <div class="menu-cat">
            <h3>🥪 Light Bites</h3>
            <div class="item"><span class="item-name">Club Sandwich</span><span class="item-desc">Chicken, bacon, lettuce, tomato</span></div>
            <div class="item"><span class="item-name">Avocado Toast</span><span class="item-desc">Sourdough with fresh avocado</span></div>
            <div class="item"><span class="item-name">Caesar Salad</span><span class="item-desc">Crisp romaine with parmesan</span></div>
        </div>
    </div>
</section>

<section id="about">
