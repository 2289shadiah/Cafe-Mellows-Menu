            <div class="item"><span class="item-name">Fresh Juices</span><span class="item-desc">Orange, Mango, Mixed</span></div>
            <div class="item"><span class="item-name">Lemonade</span><span class="item-desc">House-squeezed daily</span></div>
        </div>

        <!-- Pastries -->
        <div class="menu-cat">
