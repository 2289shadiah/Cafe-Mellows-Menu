<section id="contact">
    <h2 class="section-title">Get in Touch</h2>
    <div class="contact-details">
        <p><strong>📞 Phone:</strong> 0743234431</p>
        <p><strong>📧 Email:</strong> Cafemellows24@gmail.com</p>
    </div>
    <a href="tel:0743234431" class="btn">Call to Reserve</a>
</section>

<footer>
    <p>&copy; 2024 MellowsCafé. All Rights Reserved.</p>
</footer>

</body>
</html>
